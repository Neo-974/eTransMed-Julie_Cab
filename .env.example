# Supabase — Settings → API dans le dashboard Supabase
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGci...

# Clé service_role — UNIQUEMENT côté serveur (routes API). Ne jamais exposer au client.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGci...

# Transcription (version test, données fictives). Optionnel :
# si absent, la transcription retourne un texte vide et l'IDE saisit/corrige à la main.
# Exemple avec l'API Whisper d'OpenAI :
TRANSCRIPTION_PROVIDER=openai
OPENAI_API_KEY=sk-...
